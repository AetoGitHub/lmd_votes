# ─── LMD VOTES — Variables de entorno ───────────────────────────────────────
# Copia este archivo a .env y llena los valores:
#   cp .env.example .env

# ── Seguridad ────────────────────────────────────────────────────────────────
# Genera una clave segura con:
#   python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=cambia-esto-por-una-clave-segura-de-50-caracteres

# ── Modo debug ───────────────────────────────────────────────────────────────
# True  → desarrollo local (muestra errores en pantalla)
# False → producción (Railway)
DEBUG=True

# ── Base de datos ────────────────────────────────────────────────────────────
# Si no se define, Django usa SQLite automáticamente (solo para dev local).
# En Railway esta variable la pone el plugin PostgreSQL automáticamente.
# DATABASE_URL=postgresql://user:password@host:5432/nombre_db

# ── Railway (opcional en local) ──────────────────────────────────────────────
# Railway inyecta esta variable automáticamente. No hace falta definirla aquí.
# RAILWAY_PUBLIC_DOMAIN=tu-app.up.railway.app
